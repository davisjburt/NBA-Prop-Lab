# Copy to ".env" and fill in values (never commit ".env").
# python-dotenv loads ".env" from the project root automatically.

# --- Flask / DB ---
SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:///prop_lab.db
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Optional: Heroku Postgres URL for sync_to_heroku (refresh.sh switches to this for sync step)
# HEROKU_DATABASE_URL=

# Optional local DB when using refresh.sh with USE_LOCAL_DATABASE=1
# LOCAL_DATABASE_URL=sqlite:///instance/prop_lab_local.db

# --- Refresh digest email (SMTP) ---
# Gmail: enable 2FA, then create an App Password (Google Account → Security).
# iCloud: appleid.apple.com → App-Specific Passwords for SMTP.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-16-char-app-password
# SMTP_FROM=NBA Prop Lab <you@gmail.com>
# SMTP_USE_TLS=1
# iCloud example: SMTP_HOST=smtp.mail.me.com  SMTP_USER=you@icloud.com (or @me.com)
